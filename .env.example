# =============================================================================
# Latent Map Labs (LML) — environment variables
# =============================================================================
# Copy this file to .env.local for local development.
# On Vercel, set the same keys under Project Settings → Environment Variables.
# Never commit a populated .env or .env.local file.
# -----------------------------------------------------------------------------

# Public site URL (used for canonical links, OG metadata, absolute URLs).
# Change this for each deployment environment.
# Examples:
#   Local:      http://localhost:3000
#   Preview:    https://lml-web-git-main-<scope>.vercel.app
#   Production: https://www.latentmap.ai
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# The hostname that will be the canonical production target.
# Used by middleware to optionally redirect alternate hosts (apex -> www, etc.).
NEXT_PUBLIC_CANONICAL_HOST=www.latentmap.ai

# -----------------------------------------------------------------------------
# AUTH — invite-code gating for /platform, /team, /careers, /blog
# -----------------------------------------------------------------------------

# A 64-char hex SHA-256 hash of the invite code.
# Generate locally with:    npm run generate-hash
# Then paste the output here AND on Vercel.
# Never store the plaintext invite code anywhere.
INVITE_CODE_HASH=

# JWT signing secret. Must be at least 32 random bytes (base64url-encoded).
# Generate locally with:    npm run generate-secret
SESSION_SECRET=

# Session lifetime in seconds (default 86400 = 24h).
SESSION_TTL_SECONDS=86400

# Cookie name (no need to change unless you have a conflict).
SESSION_COOKIE_NAME=lml_session

# -----------------------------------------------------------------------------
# RATE LIMIT — protects /api/auth/login
# -----------------------------------------------------------------------------

# Max login attempts per IP per window.
RATE_LIMIT_MAX_ATTEMPTS=5

# Rate-limit window in seconds.
RATE_LIMIT_WINDOW_SECONDS=900
